# ===== docker-compose environment (copy to .env) =====

# ---- nginx 对外端口（仅 docker-compose.windows.yml 使用，Linux 版固定 80/443）----
# Windows 上 80/443 常被 IIS/HTTP.sys 占用，默认改用 8080/8443；要用 80/443 直接改这里。
HTTP_PORT=59188
HTTPS_PORT=59186

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=mt5hub
MYSQL_USER=mt5hub
MYSQL_PASSWORD=Uk7sjJl4UkhocPNWCPhocPNWCP

# ---- admin login ----
JWT_SECRET=7sjJl4Uk7sjJl4UkhocPNWCPhocPNWCP
JWT_EXPIRE_MINUTES=720
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# ---- TradingView webhook auth ----
ENABLE_AUTH=true
AUTH_TOKEN=7sjJl4UkhocPNWCP
ENABLE_IP_WHITELIST=false
WHITELISTED_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7

# ---- websocket / intervals (seconds) ----
HEARTBEAT_INTERVAL=30
ONLINE_TTL=90
ACCOUNT_REPORT_INTERVAL=5
AUTH_FIRST_PACKET_TIMEOUT=5

# ---- dispatch ----
POSITION_SCOPE=symbol
DISPATCH_MODE=sync
POLL_ACK_TIMEOUT=15
POLL_MAX_RETRY=3
DEDUP_WINDOW=5

LOG_LEVEL=INFO
