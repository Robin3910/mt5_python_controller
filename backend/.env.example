# ---- infra ----
REDIS_URL=redis://localhost:6379/0
# Local dev (no MySQL needed):
# MYSQL_DSN=sqlite+aiosqlite:///./mt5hub.db
# Production (MySQL):
MYSQL_DSN=mysql+asyncmy://mt5:mt5pwd@mysql:3306/mt5hub

# ---- webhook auth (TradingView), aligned with reference repo ----
ENABLE_AUTH=false
AUTH_TOKEN=change_me_webhook_token
ENABLE_IP_WHITELIST=false
WHITELISTED_IPS=52.89.214.238,34.212.75.30,54.218.53.128,52.32.178.7

# ---- admin auth ----
JWT_SECRET=please_change_this_secret
JWT_EXPIRE_MINUTES=720
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# ---- websocket / intervals (seconds) ----
HEARTBEAT_INTERVAL=30
ONLINE_TTL=90
ACCOUNT_REPORT_INTERVAL=5
AUTH_FIRST_PACKET_TIMEOUT=5

# ---- dispatch ----
POSITION_SCOPE=symbol
DISPATCH_MODE=sync
POLL_ACK_TIMEOUT=15
POLL_MAX_RETRY=3
DEDUP_WINDOW=5

LOG_LEVEL=INFO
