# Backend gateway (use wss:// in production behind nginx/TLS)
MANAGER_WS_URL=ws://localhost:8000/ws/node
# Global node access token (shared by ALL nodes). Get it from the admin web UI:
#   账户设置 -> 节点令牌 -> 复制
# Resetting the token from the admin UI immediately invalidates the previous one,
# so all nodes must update this value at the same time.
NODE_TOKEN=paste-global-node-token-here

# MT5_LOGIN / MT5_PASSWORD / MT5_SERVER：终端已登录则自动复用，无需输入；
# 未登录时启动交互输入。客户端须放在 MetaTrader 5 安装目录（与 terminal64.exe 同目录）。
# Set true to run without a real MT5 terminal (dev/testing)
MT5_MOCK=false

# timings (seconds)
HEARTBEAT_INTERVAL=15
ACCOUNT_REPORT_INTERVAL=5
RECONNECT_MIN=2
RECONNECT_MAX=30
AUTH_TIMEOUT=10

# trading
WATCH_SYMBOLS=XAUUSD,EURUSD,GBPUSD,USDJPY,US30,US100
DEFAULT_SLIPPAGE=20
DEFAULT_MAGIC=20240615

LOG_LEVEL=INFO
