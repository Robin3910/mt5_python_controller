# Backend gateway (use wss:// in production behind nginx/TLS)
MANAGER_WS_URL=ws://localhost:8000/ws/node
# One-time token returned by POST /api/nodes
NODE_TOKEN=paste-node-token-here

# MT5 login (on the Windows host running this client)
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=
# Set true to run without a real MT5 terminal (dev/testing)
MT5_MOCK=false

# timings (seconds)
HEARTBEAT_INTERVAL=15
ACCOUNT_REPORT_INTERVAL=5
RECONNECT_MIN=2
RECONNECT_MAX=30
AUTH_TIMEOUT=10

# trading
WATCH_SYMBOLS=XAUUSD,EURUSD,GBPUSD,USDJPY,US30,US100
DEFAULT_SLIPPAGE=20
DEFAULT_MAGIC=20240615

LOG_LEVEL=INFO
