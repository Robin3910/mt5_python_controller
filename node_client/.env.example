# ============ 后端连接 ============
# 后端网关 WebSocket 地址；节点通过它接收交易指令、上报状态。
# 本地开发用 ws://；生产经 nginx/TLS 时改成 wss://hub.example.com/ws/node
MANAGER_WS_URL=ws://159.75.33.185/ws/node
# 节点鉴权令牌：后端 POST /api/nodes 新建节点时返回的一次性 token，握手时校验
NODE_TOKEN=vlq8iAXw3cJcj0laJJ0dvVDDj6GH_YUho5vosh48ggk

# MT5_LOGIN / MT5_PASSWORD / MT5_SERVER：终端已登录则自动复用，无需输入；
# 未登录时启动交互输入。客户端须放在 MetaTrader 5 安装目录（与 terminal64.exe 同目录）。
# Set true to run without a real MT5 terminal (dev/testing)
MT5_MOCK=false

# timings (seconds)
HEARTBEAT_INTERVAL=15
ACCOUNT_REPORT_INTERVAL=5
RECONNECT_MIN=2
RECONNECT_MAX=30
AUTH_TIMEOUT=10

# trading
# 本地额外观察列表；中控台「多区间方向过滤」已配置品种会在鉴权后自动下发并合并取价
WATCH_SYMBOLS=XAUUSD,EURUSD,GBPUSD,USDJPY,US30,US100
DEFAULT_SLIPPAGE=20
DEFAULT_MAGIC=20240615

LOG_LEVEL=INFO
